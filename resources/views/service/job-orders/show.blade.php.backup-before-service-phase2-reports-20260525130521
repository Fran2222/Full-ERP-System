        $formatDate = function ($value, $withTime = false) {
            if (empty($value)) {
                return '-';
            }

            try {
                return \Carbon\Carbon::parse($value)->format($withTime ? 'M d, Y h:i A' : 'M d, Y');
            } catch (\Throwable $e) {
                return $value;
            }
        };
