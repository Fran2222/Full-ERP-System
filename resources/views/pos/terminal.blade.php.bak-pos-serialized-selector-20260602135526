    <script>
                function hasPosSelect2() {
            return window.jQuery && typeof window.jQuery.fn.select2 === 'function';
        }

        function loadPosSelect2Assets(callback) {
            if (hasPosSelect2()) {
                callback();
                return;
            }

            if (!document.getElementById('pos-select2-css')) {
                const css = document.createElement('link');
                css.id = 'pos-select2-css';
                css.rel = 'stylesheet';
                css.href = 'https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css';
                document.head.appendChild(css);
            }

            if (!document.getElementById('pos-select2-js')) {
                const script = document.createElement('script');
                script.id = 'pos-select2-js';
                script.src = 'https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js';
                script.onload = callback;
                document.body.appendChild(script);
            } else {
                const waitForSelect2 = setInterval(function () {
                    if (hasPosSelect2()) {
                        clearInterval(waitForSelect2);
                        callback();
                    }
                }, 100);
            }
        }

        function initPosCustomerSelect2() {
            if (!hasPosSelect2()) {
                return;
            }

            const $select = window.jQuery('#posCustomer');

            if (!$select.length || $select.hasClass('select2-hidden-accessible')) {
                return;
            }

            $select.select2({
                width: '100%',
                placeholder: $select.data('placeholder') || 'Search customer...',
                allowClear: false,
                dropdownParent: window.jQuery('.pos-customer-box'),
                dropdownCssClass: 'pos-customer-select2-dropdown'
            });
        }
        document.addEventListener('DOMContentLoaded', function () {
            const productCards = Array.from(document.querySelectorAll('.pos-product-card'));
            const searchInput = document.getElementById('posProductSearch');
            const searchButton = document.getElementById('posSearchButton');
            const filterButtons = Array.from(document.querySelectorAll('.pos-filter'));
            const noResults = document.getElementById('posNoResults');
            const cartItems = document.getElementById('posCartItems');
            const cartEmpty = document.getElementById('posCartEmpty');
            const cartCount = document.getElementById('posCartCount');
            const subtotalEl = document.getElementById('posSubtotal');
            const discountEl = document.getElementById('posDiscount');
            const taxEl = document.getElementById('posTax');
            const totalEl = document.getElementById('posTotal');
            const amountPaidEl = document.getElementById('posAmountPaid');
            const balanceEl = document.getElementById('posBalance');
            const completeBtn = document.getElementById('posCompleteSale');
            const paymentStatusButtons = Array.from(document.querySelectorAll('#posPaymentStatus button'));
            const paymentMethod = document.getElementById('posPaymentMethod');
            const customerSelect = document.getElementById('posCustomer');
            loadPosSelect2Assets(initPosCustomerSelect2);
            const saleForm = document.getElementById('posSaleForm');
            const submitCustomer = document.getElementById('posSubmitCustomer');
            const submitPaymentStatus = document.getElementById('posSubmitPaymentStatus');
            const submitPaymentMethod = document.getElementById('posSubmitPaymentMethod');
            const submitAmountPaid = document.getElementById('posSubmitAmountPaid');
            const submitItems = document.getElementById('posSubmitItems');

            let activeFilter = 'all';
            let paymentStatus = 'paid';
            const cart = new Map();

            const peso = new Intl.NumberFormat('en-PH', {
                style: 'currency',
                currency: 'PHP',
                minimumFractionDigits: 2,
            });

            function money(value) {
                return peso.format(Number(value || 0));
            }

            function cartTotal() {
                let total = 0;
                cart.forEach(item => total += item.price * item.qty);
                return total;
            }

            function applyProductFilter() {
                const term = (searchInput.value || '').trim().toLowerCase();
                let visible = 0;

                productCards.forEach(card => {
                    const keywords = card.dataset.keywords || '';
                    const available = Number(card.dataset.available || 0);
                const serialized = card.dataset.serialized === '1';


                    let matchesFilter = true;
                    if (activeFilter === 'available') matchesFilter = available > 0;
                    if (activeFilter === 'serialized') matchesFilter = serialized;
                    if (activeFilter === 'low-stock') matchesFilter = available > 0 && available <= 3;

                    const matchesSearch = !term || keywords.includes(term);
                    const show = matchesFilter && matchesSearch;

                    card.classList.toggle('pos-hidden', !show);
                    if (show) visible++;
                });

                if (noResults) {
                    noResults.classList.toggle('d-none', visible > 0);
                }
            }

            function setPaymentStatus(status) {
                paymentStatus = status;
                paymentStatusButtons.forEach(btn => btn.classList.toggle('active', btn.dataset.status === status));

                const total = cartTotal();
                if (status === 'paid') {
                    amountPaidEl.value = total.toFixed(2);
                    amountPaidEl.readOnly = false;
                    paymentMethod.value = 'cash';
                } else if (status === 'partial') {
                    if (Number(amountPaidEl.value || 0) >= total) {
                        amountPaidEl.value = '0.00';
                    }
                    amountPaidEl.readOnly = false;
                } else {
                    amountPaidEl.value = '0.00';
                    amountPaidEl.readOnly = true;
                    paymentMethod.value = 'credit';
                }

                renderCart();
            }

            function addToCart(card) {
                const id = String(card.dataset.productId || '');
                const name = card.dataset.name || 'Unnamed Item';
                const code = card.dataset.code || 'NO-CODE';
                const price = Number(card.dataset.price || 0);
                const available = Number(card.dataset.available || 0);
                const serialized = card.dataset.serialized === '1';

                if (!id || available <= 0) {
                    alert('This item has no available branch stock.');
                    return;
                }

                const existing = cart.get(id);
                if (existing) {
                    if (existing.qty + 1 > existing.available) {
                        alert('Quantity cannot exceed available branch stock.');
                        return;
                    }
                    existing.qty += 1;
                } else {
                    cart.set(id, { id, name, code, price, available, serialized, qty: 1 });
                }

                renderCart();
            }

            function changeQty(id, delta) {
                const item = cart.get(String(id));
                if (!item) return;

                const nextQty = item.qty + delta;
                if (nextQty <= 0) {
                    cart.delete(String(id));
                } else if (nextQty > item.available) {
                    alert('Quantity cannot exceed available branch stock.');
                } else {
                    item.qty = nextQty;
                }

                renderCart();
            }

            function removeItem(id) {
                cart.delete(String(id));
                renderCart();
            }

            function renderCart() {
                const itemCount = Array.from(cart.values()).reduce((sum, item) => sum + item.qty, 0);
                const subtotal = cartTotal();
                const discount = 0;
                const tax = 0;
                const total = subtotal - discount + tax;

                cartCount.textContent = itemCount + (itemCount === 1 ? ' item' : ' items');
                subtotalEl.textContent = money(subtotal);
                discountEl.textContent = money(discount);
                taxEl.textContent = money(tax);
                totalEl.textContent = money(total);

                cartEmpty.classList.toggle('d-none', cart.size > 0);
                cartItems.classList.toggle('d-none', cart.size === 0);
                completeBtn.disabled = cart.size === 0;

                cartItems.innerHTML = '';
                cart.forEach(item => {
                    const line = document.createElement('div');
                    line.className = 'pos-cart-line';
                    line.innerHTML = `
                        <div class="pos-cart-line-top">
                            <div>
                                <div class="pos-cart-line-name">${escapeHtml(item.name)}</div>
                                <div class="pos-cart-line-code">${escapeHtml(item.code)} • Available ${item.available}</div>
                            </div>
                            <div class="pos-cart-line-price">${money(item.price * item.qty)}</div>
                        </div>
                        <div class="pos-cart-controls">
                            <div class="pos-qty-controls">
                                <button type="button" data-action="minus" data-id="${item.id}">−</button>
                                <span class="pos-line-qty">${item.qty}</span>
                                <button type="button" data-action="plus" data-id="${item.id}">+</button>
                            </div>
                            <button type="button" class="pos-remove-line" data-action="remove" data-id="${item.id}">Remove</button>
                        </div>
                    `;
                    cartItems.appendChild(line);
                });

                if (paymentStatus === 'paid') {
                    amountPaidEl.value = total.toFixed(2);
                } else if (paymentStatus === 'unpaid') {
                    amountPaidEl.value = '0.00';
                }

                let paid = Number(amountPaidEl.value || 0);
                if (paid > total) paid = total;
                const balance = Math.max(total - paid, 0);
                balanceEl.value = balance.toFixed(2);
            }

            function escapeHtml(value) {
                return String(value || '')
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#039;');
            }

            productCards.forEach(card => card.addEventListener('click', () => addToCart(card)));
            searchInput.addEventListener('input', applyProductFilter);
            searchButton.addEventListener('click', applyProductFilter);

            filterButtons.forEach(button => {
                button.addEventListener('click', function () {
                    activeFilter = this.dataset.filter || 'all';
                    filterButtons.forEach(btn => btn.classList.remove('active'));
                    this.classList.add('active');
                    applyProductFilter();
                });
            });

            cartItems.addEventListener('click', function (event) {
                const button = event.target.closest('button[data-action]');
                if (!button) return;
                const id = button.dataset.id;
                const action = button.dataset.action;
                if (action === 'plus') changeQty(id, 1);
                if (action === 'minus') changeQty(id, -1);
                if (action === 'remove') removeItem(id);
            });

            paymentStatusButtons.forEach(button => {
                button.addEventListener('click', function () {
                    setPaymentStatus(this.dataset.status || 'paid');
                });
            });

            amountPaidEl.addEventListener('input', renderCart);

            saleForm.addEventListener('submit', function (event) {
                if (!cart.size) {
                    event.preventDefault();
                    return;
                }

                const hasSerialized = Array.from(cart.values()).some(item => item.serialized);
                if (hasSerialized) {
                    event.preventDefault();
                    alert('Serialized item selling needs serial number selection. This will be added in the next POS patch. Please remove serialized items first.');
                    return;
                }

                const total = cartTotal();
                const paid = Number(amountPaidEl.value || 0);

                if (paymentStatus === 'partial' && (paid <= 0 || paid >= total)) {
                    event.preventDefault();
                    alert('Partial payment must be greater than 0 and less than the total.');
                    return;
                }

                submitCustomer.value = customerSelect.value || '';
                submitPaymentStatus.value = paymentStatus;
                submitPaymentMethod.value = paymentMethod.value || 'cash';
                submitAmountPaid.value = amountPaidEl.value || '0';
                submitItems.value = JSON.stringify(Array.from(cart.values()).map(item => ({
                    id: item.id,
                    qty: item.qty,
                })));

                completeBtn.disabled = true;
                completeBtn.textContent = 'Saving Sale...';
            });

            setPaymentStatus('paid');
            applyProductFilter();
        });
    </script>
</x-app-layout>

