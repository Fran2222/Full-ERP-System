                    scrollCollapse: true,
                    autoWidth: false,
                    pageLength: 10,
                    lengthMenu: [10, 25, 50, 100],
                    ajax: {
                        url: "{{ route('warehouse.inventory') }}",
                        data: function (d) {
                            d.branch_id = $('#inventory-branch-filter').val();
                            d.location_id = $('#inventory-location-filter').val();
                        }
                    },
                    order: [[0, 'desc']],
                    searchDelay: 250,
                    columns: [
                        {
                            data: 'DT_RowIndex',
                            name: 'DT_RowIndex',
                            orderable: false,
                            searchable: false
                        },
                        {
