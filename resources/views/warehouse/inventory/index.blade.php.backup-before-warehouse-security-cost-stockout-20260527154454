                            name: 'category_name',
                            orderable: false
                        },
                        {
                            data: 'branch_name',
                            name: 'branch_name',
                            orderable: false
                        },
                        {
                            data: 'location_name',
                            name: 'location_name',
                            orderable: false
                        },
                        {
                            data: 'unit_name',
                            name: 'unit_name',
                            orderable: false
                        },
                        {
                            data: 'on_hand_quantity',
                            name: 'on_hand_quantity',
                            orderable: false,
