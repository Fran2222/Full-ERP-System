    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.getElementById('warehouseTransferForm');

            function hasWarehouseSelect2() {
                return window.jQuery && typeof jQuery.fn.select2 === 'function';
            }

            function loadWarehouseSelect2Assets(callback) {
                if (!window.jQuery) {
                    return;
                }

                if (hasWarehouseSelect2()) {
                    callback();
                    return;
                }

                if (!document.getElementById('warehouse-select2-css')) {
                    const css = document.createElement('link');
                    css.id = 'warehouse-select2-css';
                    css.rel = 'stylesheet';
                    css.href = 'https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css';
                    document.head.appendChild(css);
                }

                if (!document.getElementById('warehouse-select2-js')) {
                    const script = document.createElement('script');
                    script.id = 'warehouse-select2-js';
                    script.src = 'https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js';
                    script.onload = callback;
                    document.body.appendChild(script);
                } else {
                    const waitForSelect2 = setInterval(function () {
                        if (hasWarehouseSelect2()) {
                            clearInterval(waitForSelect2);
                            callback();
                        }
                    }, 100);
                }
            }

            function initWarehouseItemSelect2() {
                if (!hasWarehouseSelect2()) {
                    return;
                }

                $('.warehouse-item-select').each(function () {
                    const $select = $(this);

                    if ($select.hasClass('select2-hidden-accessible')) {
                        return;
                    }

                    $select.select2({
                        width: '100%',
                        placeholder: $select.data('placeholder') || 'Search item code or name...',
                        allowClear: true,
                        dropdownCssClass: 'warehouse-select2-dropdown',
                        matcher: function (params, data) {
                            if ($.trim(params.term) === '') {
                                return data;
                            }

                            if (typeof data.text === 'undefined') {
                                return null;
                            }

                            const term = params.term.toLowerCase();
                            const text = data.text.toLowerCase();
                            const element = data.element;
                            const code = element ? String($(element).data('code') || '').toLowerCase() : '';
                            const name = element ? String($(element).data('name') || '').toLowerCase() : '';

                            if (text.indexOf(term) > -1 || code.indexOf(term) > -1 || name.indexOf(term) > -1) {
                                return data;
                            }

                            return null;
                        }
                    });
                });
            }

            function confirmTransfer() {
                if (window.Swal) {
                    return Swal.fire({
                        icon: 'question',
                        title: 'Post stock transfer?',
                        text: 'This will deduct stock from the source location and add it to the destination location.',
                        showCancelButton: true,
                        confirmButtonText: 'Yes, save transfer',
                        cancelButtonText: 'Cancel',
                        confirmButtonColor: '#315cf6',
                        reverseButtons: true
                    }).then(result => result.isConfirmed);
                }

                return Promise.resolve(confirm('Post this stock transfer?'));
            }

            if (form) {
                form.addEventListener('submit', function (event) {
                    event.preventDefault();

                    confirmTransfer().then(function (confirmed) {
                        if (confirmed) {
                            form.submit();
                        }
                    });
                });
            }

            loadWarehouseSelect2Assets(function () {
                initWarehouseItemSelect2();
            });
        });
    </script>

{{-- wmc-transfer-nonserialized-qty-unlock-fix-start --}}
<script>
(function () {
    'use strict';

    if (!window.location.pathname.includes('/warehouse/transfer')) return;

    function qs(selector, root) {
        return (root || document).querySelector(selector);
    }

    function qsa(selector, root) {
        return Array.prototype.slice.call((root || document).querySelectorAll(selector));
    }

    function isVisible(el) {
        return !!(el && el.offsetParent !== null && !el.classList.contains('d-none'));
    }

    function pickerLooksSerialized(detail) {
        if (detail && detail.item && (detail.item.is_serialized === true || detail.item.is_serialized === 1 || detail.item.is_serialized === '1')) {
            return true;
        }

        var typeText = (qs('#wmcItemPickerType') ? qs('#wmcItemPickerType').textContent : '').toLowerCase();
        if (typeText.includes('serialized')) return true;

        var serialBox = qs('#wmcItemPickerSerialBox');
        if (isVisible(serialBox)) return true;

        return false;
    }

    function findTransferQtyInput() {
        return qs('#warehouseTransferForm input[name="quantity"], form[action*="transfer"] input[name="quantity"], input[name="quantity"]');
    }

    function unlockPickerQuantityIfNonSerialized(detail) {
        var isSerialized = pickerLooksSerialized(detail);
        var pickerQty = qs('#wmcItemPickerQty');
        var pickerHelp = qs('#wmcItemPickerQtyHelp');

        if (pickerQty && !isSerialized) {
            pickerQty.disabled = false;
            pickerQty.readOnly = false;
            pickerQty.removeAttribute('disabled');
            pickerQty.removeAttribute('readonly');
            pickerQty.classList.remove('disabled');

            if (!pickerQty.value || Number(pickerQty.value) <= 0) {
                pickerQty.value = '1';
            }

            if (pickerHelp) {
                pickerHelp.textContent = 'Enter quantity to transfer. Cannot exceed available quantity.';
            }
        }

        if (pickerQty && isSerialized) {
            pickerQty.readOnly = true;
            pickerQty.value = pickerQty.value || '1';
            if (pickerHelp) {
                pickerHelp.textContent = 'Serialized transfer quantity follows selected serial.';
            }
        }
    }

    function unlockTransferFormQuantityIfNonSerialized(detail) {
        var qty = findTransferQtyInput();
        if (!qty) return;

        var isSerialized = pickerLooksSerialized(detail);

        if (!isSerialized) {
            qty.disabled = false;
            qty.readOnly = false;
            qty.removeAttribute('disabled');
            qty.removeAttribute('readonly');
            qty.classList.remove('disabled');
            qty.step = qty.step || '0.01';
            qty.min = qty.min || '0.01';

            var pickedQty = detail && detail.quantity ? detail.quantity : null;
            if (pickedQty && Number(pickedQty) > 0) {
                qty.value = pickedQty;
            } else if (!qty.value || Number(qty.value) <= 0) {
                qty.value = '1';
            }

            qty.dispatchEvent(new Event('input', { bubbles: true }));
            qty.dispatchEvent(new Event('change', { bubbles: true }));
        } else {
            qty.readOnly = true;
            if (!qty.value || Number(qty.value) <= 0) qty.value = '1';
        }
    }

    document.addEventListener('wmc:item-picker:selected', function (event) {
        var detail = event.detail || {};
        setTimeout(function () {
            unlockPickerQuantityIfNonSerialized(detail);
            unlockTransferFormQuantityIfNonSerialized(detail);
        }, 30);
        setTimeout(function () {
            unlockPickerQuantityIfNonSerialized(detail);
            unlockTransferFormQuantityIfNonSerialized(detail);
        }, 250);
    });

    document.addEventListener('click', function (event) {
        if (event.target.closest('#wmcItemPickerResults tr') || event.target.closest('.wmc-open-item-picker, #transferOpenPickerBtn, .transfer-open-picker-btn')) {
            setTimeout(function () { unlockPickerQuantityIfNonSerialized(null); }, 80);
            setTimeout(function () { unlockPickerQuantityIfNonSerialized(null); }, 300);
        }
    });

    document.addEventListener('input', function (event) {
        if (event.target && event.target.id === 'wmcItemPickerQty') {
            var qty = findTransferQtyInput();
            if (qty && !pickerLooksSerialized(null)) {
                qty.disabled = false;
                qty.readOnly = false;
                qty.value = event.target.value;
            }
        }
    });

    var observer = new MutationObserver(function () {
        unlockPickerQuantityIfNonSerialized(null);
    });

    document.addEventListener('DOMContentLoaded', function () {
        var modal = qs('#wmcItemPickerModal');
        if (modal) {
            observer.observe(modal, { childList: true, subtree: true, attributes: true, attributeFilter: ['class', 'disabled', 'readonly', 'style'] });
        }
        setTimeout(function () { unlockTransferFormQuantityIfNonSerialized(null); }, 300);
    });
})();
</script>
{{-- wmc-transfer-nonserialized-qty-unlock-fix-end --}}
</x-app-layout>

