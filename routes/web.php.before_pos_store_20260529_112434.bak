        Route::get('/vehicles/{vehicle}', [VehicleController::class, 'show'])
            ->middleware('vehicle.manager')
            ->name('vehicles.show');
        Route::get('/vehicles/{vehicle}/edit', [VehicleController::class, 'edit'])
            ->middleware('vehicle.manager')
            ->name('vehicles.edit');
        Route::put('/vehicles/{vehicle}', [VehicleController::class, 'update'])
