    Route::delete('/announcements/{announcement}', [AnnouncementController::class, 'destroy'])
        ->middleware('permission:announcements.delete')
        ->name('announcements.destroy');

    /*
    |--------------------------------------------------------------------------
    | Dashboard
    |--------------------------------------------------------------------------
    */
    Route::get('/dashboard', function (\Illuminate\Http\Request $request) {
        $user = auth()->user();

        if (
            $user
            && ($user->can('hr.dashboard.view') || $user->can('hr.view'))
            && ! $user->hasAnyRole(['Super Admin', 'Super Administrator', 'Admin', 'super admin', 'super-admin', 'superadmin', 'admin'])
        ) {
            return redirect()->route('hr.dashboard');
        }

        return app(HomeController::class)->index($request);
    })
        ->middleware('permission:dashboard.view|hr.dashboard.view|hr.view')
        ->name('dashboard');

